{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entry Window Chart",
  "description": "Local-only MVP schema for an as-of Entry Window Radar diagnosis, with chart_data defined for future Entry Window Map display.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "as_of",
    "entry_label",
    "market_line",
    "competition_line",
    "operator_edge_line",
    "rationale",
    "maximum_bottleneck",
    "next_action",
    "confidence",
    "missing_evidence",
    "risk",
    "recheck_condition"
  ],
  "properties": {
    "as_of": {
      "type": "string",
      "description": "As-of date or timestamp for the judgment."
    },
    "entry_label": {
      "type": "string",
      "enum": ["FAST ENTRY", "NICHE WEDGE", "WAIT", "SHORT CYCLE", "AVOID"]
    },
    "market_line": {
      "$ref": "#/$defs/line"
    },
    "competition_line": {
      "$ref": "#/$defs/line"
    },
    "operator_edge_line": {
      "$ref": "#/$defs/line"
    },
    "rationale": {
      "type": "string",
      "description": "Short explanation for why the as-of entry label fits the available evidence."
    },
    "maximum_bottleneck": {
      "type": "string",
      "description": "Exactly one current bottleneck limiting the entry-window diagnosis.",
      "minLength": 1
    },
    "next_action": {
      "type": "string",
      "description": "Exactly one bounded next action for improving or testing the as-of diagnosis.",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "description": "Evidence-completeness confidence, not prediction confidence.",
      "enum": ["Low", "Low-medium", "Medium", "High"]
    },
    "missing_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risk": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recheck_condition": {
      "type": "string"
    }
  },
  "$defs": {
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "signals", "open_questions"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "signals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "chart_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "as_of",
        "target",
        "market_readiness",
        "operator_edge",
        "competition_pressure",
        "entry_label",
        "maximum_bottleneck",
        "next_action",
        "confidence",
        "missing_evidence",
        "interpretation_note"
      ],
      "properties": {
        "as_of": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "market_readiness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Display-stage level, not a probability."
        },
        "operator_edge": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Display-stage level, not a probability."
        },
        "competition_pressure": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Display-stage level, not a probability."
        },
        "entry_label": {
          "type": "string",
          "enum": ["FAST ENTRY", "NICHE WEDGE", "WAIT", "SHORT CYCLE", "AVOID"]
        },
        "maximum_bottleneck": {
          "type": "string",
          "minLength": 1
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string"
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "interpretation_note": {
          "type": "string",
          "description": "Must say these levels are display-stage, not precise probabilities, future predictions, VC scores, or investment advice."
        }
      }
    }
  }
}
